OPENAI_API_KEY=sk-your-api-key
OPENAI_STT_MODEL=whisper-1
OPENAI_SUMMARY_MODEL=gpt-4o-mini
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006
AUDIO_TRANSCRIPTION_CONCURRENCY=3
AUDIO_CHUNK_MIN_SECONDS=300
AUDIO_CHUNK_MAX_SECONDS=900
AUDIO_CHUNK_OVERLAP_SECONDS=2
AUDIO_TARGET_CHUNK_MAX_MB=24
SUMMARY_TEXT_CHUNK_CHARS=16000
SUMMARY_CONCURRENCY=2
DATABASE_URL=postgresql://postgres:1234@localhost:5432/recordoc
# 템플릿 기반 요약 PDF 생성 설정 (모두 기본값 있음)
SUMMARY_PDF_MODEL=gpt-4o-mini
SUMMARY_PDF_MAX_INPUT_CHARS=48000
# 한글 글꼴 경로 — 비우면 번들 글꼴(assets/fonts/NotoSansKR-Regular.otf) 사용
SUMMARY_PDF_FONT_PATH=

# JWT 인증 설정 — JWT_SECRET_KEY는 반드시 충분히 긴 랜덤 문자열로 교체할 것
JWT_SECRET_KEY=change-this-to-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Google OAuth (console.cloud.google.com에서 발급)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Kakao OAuth (developers.kakao.com — REST API 키)
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=

# Naver OAuth (developers.naver.com에서 발급)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_REDIRECT_URI=
